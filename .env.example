# Copia este archivo a .env.local y rellena los valores.

# Supabase (Settings > API en el dashboard de Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=
EMAIL_FROM=Álbum Mundial 2026 <noreply@tu-dominio.com>

# Admin precargado por scripts/seed-admin.mjs
ADMIN_EMAIL=
ADMIN_NAME=
ADMIN_PASSWORD=

# Sesiones (HMAC) — genera con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# URL pública del sitio (para los magic links en emails)
NEXT_PUBLIC_SITE_URL=
